// scripts/createNewEthereumIdentity.js

const { randomBytes } = require("crypto");

function generateEthereumAddress() {
  // Simule une adresse Ethereum (40 hex chars)
  return "0x" + randomBytes(20).toString("hex");
}

function generatePrivateKey() {
  return "0x" + randomBytes(32).toString("hex");
}

function main() {
  console.log("🔐 Creating new Ethereum identity...");

  const address = generateEthereumAddress();
  const privateKey = generatePrivateKey();

  console.log("✅ Identity created:");
  console.log("Address:", address);
  console.log("Private Key:", privateKey);

  // Optionnel : sauvegarde dans un fichier
  const fs = require("fs");
  const data = { address, privateKey };

  fs.writeFileSync("identity.json", JSON.stringify(data, null, 2));
  console.log("💾 Saved to identity.json");
}

main();
